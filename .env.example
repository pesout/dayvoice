# ===== Database (MySQL) =====
DB_HOST=db                # hostname databáze (v Docker síti název služby "db")
DB_PORT=3306              # port MySQL
DB_USERNAME=              # MySQL uživatel
DB_PASSWORD=              # MySQL heslo
DB_DATABASE=dayvoice      # název databáze

# ===== Authentication =====
JWT_SECRET=               # náhodný řetězec pro podepisování JWT tokenů (min. 32 znaků)
JWT_EXPIRATION=7d         # doba platnosti tokenu (např. 7d, 24h)

# ===== OpenAI API =====
OPENAI_API_KEY=           # API klíč z https://platform.openai.com/api-keys
WHISPER_MODEL=whisper-1   # model pro přepis audia
GPT_MODEL=gpt-4o          # model pro generování textu

# ===== LLM nastavení =====
LLM_TEMPERATURE=0.3       # kreativita odpovědí (0.0 = deterministické, 1.0 = kreativní)
LLM_MAX_TOKENS=1024       # maximální délka odpovědi v tokenech

# ===== Denní souhrn =====
DAILY_DIGEST_CRON_HOUR=04:00  # hodina generování denního souhrnu (HH:MM)

# ===== Upload =====
UPLOAD_DIR=./uploads       # cesta pro ukládání audio souborů
